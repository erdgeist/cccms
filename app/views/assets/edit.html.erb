<h1>Editing asset</h1>

<%= form_for(@asset, html: { multipart: true }) do |f| %>
  <%= form_error_messages(f) %>

  <% if @asset.upload.present? %>
    <p>
      <strong>Current file:</strong>
      <%= @asset.upload.url %>
      (<%= number_to_human_size(@asset.upload.size) %>)
    </p>
  <% end %>

  <p>
    <label>Replace file:</label><br>
    <%= f.file_field :upload %>
  </p>

  <p>
    <%= f.submit 'Update' %>
  </p>
<% end %>

<%= link_to 'Show', @asset %> | <%= link_to 'Back', assets_path %>
