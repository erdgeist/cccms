<% users.each do |user| %>
<tr>
  <td class="user_login"><%= user.login %></td>
  <td><%= link_to "show", user_path(user) %></td>
  <% if current_user.admin? || current_user == user %>
  <td>
    <%= link_to "edit", edit_user_path(user) %>
  </td>
  <td>
    <%= button_to "destroy", user_path(user),
          method: :delete,
          form: { data: { confirm: "Do you really want to delete user #{user.login}?" } } %>
  </td>
  <% end %>
</tr>
<% end %>
